# Community backend API base URL.
VITE_API_URL=http://localhost:4000

# Main app FRONTEND — used for login redirects and the collab→invite deep link.
VITE_MAIN_APP_URL=https://app.brainjot.space

# Main app BACKEND API — a separate domain/Vercel project from the frontend
# above. This is what actually serves GET /api/community/sso-token. If your
# main app's frontend and backend are the same origin, you can omit this and
# it'll fall back to VITE_MAIN_APP_URL.
VITE_MAIN_API_URL=https://your-main-app-backend.vercel.app
