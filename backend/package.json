{
  "name": "brainjot-community-backend",
  "version": "1.0.0",
  "description": "Standalone backend for the brainjot Community (community.brainjot.space). Fully isolated from the main app: own DB, own deploy. Shares identity with the main app via SSO only.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "connect-mongo": "^6.0.0",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.6",
    "dompurify": "^3.4.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.4.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^4.7.0",
    "web-push": "^3.6.7"
  }
}
