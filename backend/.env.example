# ── brainjot Community backend — environment ────────────────────────────────
# Copy to .env and fill in. NEVER commit .env.

NODE_ENV=development
PORT=4000

# Separate database — do NOT point this at the main app's DB.
# Full isolation is the whole point: a community spike must never touch the app.
MONGODB_URI=mongodb://127.0.0.1:27017/brainjot_community

# Community's own session signing secret (independent from the main app).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Optional: previous secret to allow zero-downtime rotation.
SESSION_SECRET_PREVIOUS=

# Shared SSO secret — MUST match COMMUNITY_JWT_SECRET on the main app.
# This is the only cryptographic link between the two systems. Tokens are
# verified locally here, so the main app is hit at most once per login.
COMMUNITY_JWT_SECRET=

# Where the main app lives (used for SSO redirects + the collab→invite deep link).
MAIN_APP_URL=https://app.brainjot.space
# Public URL of this community app (used for cookie/redirect correctness).
COMMUNITY_APP_URL=https://community.brainjot.space

# Comma-separated extra allowed CORS origins (the community frontend, previews…).
ALLOWED_ORIGINS=http://localhost:5174,https://community.brainjot.space

# ── Scale flip-switches (leave blank for single-instance; set to go horizontal) ─
# When REDIS_URL is set, sessions + socket.io + rate-limits move to Redis,
# letting you run N stateless backend instances behind a load balancer.
REDIS_URL=

# Mongo connection pool ceiling per instance (prevents connection exhaustion
# when you run many instances against Atlas). Tune with your cluster tier.
MONGO_MAX_POOL=20

# ── Optional: photo/PDF uploads (Cloudflare R2). Leave blank to disable. ──
# These 5 keys use the SAME NAMES as the main app's backend — if the main app
# already has R2 configured, just copy its values here as-is. Files are stored
# under a `community/` key prefix, so nothing overlaps with the main app's own
# uploads even when sharing one bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
